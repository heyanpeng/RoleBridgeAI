{
  "name": "rolebridgeai-monorepo",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "pnpm --filter @rolebridgeai/frontend dev",
    "build:frontend": "pnpm --filter @rolebridgeai/frontend build",
    "deploy:frontend": "pnpm --filter @rolebridgeai/frontend run deploy",
    "lint:frontend": "pnpm --filter @rolebridgeai/frontend lint",
    "preview:frontend": "pnpm --filter @rolebridgeai/frontend preview",
    "dev:backend": "pnpm --filter @rolebridgeai/backend dev",
    "build:backend": "pnpm --filter @rolebridgeai/backend build",
    "start:backend": "pnpm --filter @rolebridgeai/backend start"
  }
}
